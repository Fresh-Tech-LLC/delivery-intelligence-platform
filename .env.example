# =============================================================================
# Project Delivery Copilot — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to source control.
# =============================================================================

# -----------------------------------------------------------------------------
# LLM Adapter — select which backend to use
# openai_chat        : OpenAI-compatible REST endpoint (default)
# model_engine_ask   : SEMOSS ai-server-sdk ModelEngine
# -----------------------------------------------------------------------------
LLM_ADAPTER_TYPE=openai_chat

# -----------------------------------------------------------------------------
# LLM — OpenAI-compatible (used when LLM_ADAPTER_TYPE=openai_chat)
# -----------------------------------------------------------------------------
LLM_API_BASE=https://api.openai.com/v1
LLM_MODEL_NAME=gpt-4o
# Standard API key auth (use this OR access_key/secret_key below, not both)
LLM_API_KEY=sk-...
# Alternative auth for APIs that use access_key + secret_key (sent as "access_key:secret_key" Bearer token)
# LLM_ACCESS_KEY=your-access-key
# LLM_SECRET_KEY=your-secret-key

# -----------------------------------------------------------------------------
# LLM — SEMOSS ModelEngine (used when LLM_ADAPTER_TYPE=model_engine_ask)
# -----------------------------------------------------------------------------
# LLM_API_BASE=https://your-semoss-server
# LLM_MODEL_NAME=vertexgemini25pro
# LLM_ACCESS_KEY=your-access-key
# LLM_SECRET_KEY=your-secret-key

# Optional tuning
LLM_TIMEOUT=120
LLM_MAX_RETRIES=2
LLM_MAX_TOKENS=4096
# Set to false for models that reject the temperature parameter (e.g. gpt-5, o1, o3, o4)
LLM_TEMPERATURE_SUPPORTED=true
# Optional deterministic seed (provider/model dependent)
# LLM_SEED=42
# Path to a custom CA bundle for self-signed/corporate TLS certificates (leave blank if not needed)
# LLM_CA_BUNDLE=C:/path/to/your/certificate.pem

# -----------------------------------------------------------------------------
# Jira (leave blank to run without Jira; dry-run still works)
# -----------------------------------------------------------------------------
JIRA_BASE_URL=https://yourcompany.atlassian.net
# If your Jira is hosted behind a context path, include it in base URL (example):
# JIRA_BASE_URL=https://yourcompany.example.com/jira
JIRA_USER=you@yourcompany.com
JIRA_API_TOKEN=your-jira-api-token
# Auth mode: basic | bearer | auto
# - basic: uses JIRA_USER + JIRA_API_TOKEN
# - bearer: uses JIRA_BEARER_TOKEN (or JIRA_API_TOKEN if bearer token is blank)
# - auto: prefers bearer when JIRA_BEARER_TOKEN is set, otherwise basic
JIRA_AUTH_MODE=basic
# Optional dedicated bearer token
# JIRA_BEARER_TOKEN=your-bearer-token
JIRA_PROJECT_KEY=PROJ
# Optional user-maintained PM prompt override file (outside git-managed base prompt)
# Example contents: custom field names, team names, workflow terms, project conventions.
PM_USER_PROMPT_FILE=local_data/prompt_overrides/pm_jira_query_user.md
# Safety cap for loaded override size
PM_USER_PROMPT_MAX_CHARS=20000

# Optional
JIRA_TIMEOUT=30
# Disable TLS certificate verification for Jira requests (insecure; for self-signed cert environments)
JIRA_VERIFY_SSL=false

# -----------------------------------------------------------------------------
# Knowledge / Ingestion (Phase 1)
# -----------------------------------------------------------------------------
# Set to false to skip saving raw source payloads to local_data/knowledge/raw/
KNOWLEDGE_RAW_CAPTURE_ENABLED=true
# Default project key used when none is passed to ingest endpoints (falls back to JIRA_PROJECT_KEY if blank)
# KNOWLEDGE_DEFAULT_PROJECT_KEY=MYPROJ
# Root directory scanned by the local-docs ingestor
KNOWLEDGE_LOCAL_DOCS_DIR=local_data/knowledge_docs
# Maximum Jira issues fetched per run (overridable per-request)
KNOWLEDGE_JIRA_MAX_RESULTS=200
# Maximum file size (bytes) for local doc ingestion — files exceeding this are skipped
KNOWLEDGE_MAX_FILE_BYTES=20971520

# -----------------------------------------------------------------------------
# Knowledge / Retrieval (Phase 2)
# -----------------------------------------------------------------------------
# Target chunk size in characters before section/window splitting
KNOWLEDGE_CHUNK_TARGET_CHARS=2000
# Character overlap used when a section must be split into windows
KNOWLEDGE_CHUNK_OVERLAP_CHARS=200
# Safety cap for the number of chunks created from one artifact
KNOWLEDGE_MAX_CHUNKS_PER_ARTIFACT=200
# Preserve case in the lexical index (false recommended for local development)
KNOWLEDGE_INDEX_CASE_SENSITIVE=false
# Default and maximum result limits for chunk retrieval
KNOWLEDGE_SEARCH_DEFAULT_LIMIT=20
KNOWLEDGE_SEARCH_MAX_LIMIT=100
# Rebuild the lexical index automatically after chunk ingestion
KNOWLEDGE_REBUILD_INDEX_ON_CHUNK_INGEST=true

# -----------------------------------------------------------------------------
# Knowledge / Graph + Appian (Phase 3)
# -----------------------------------------------------------------------------
# Root directory scanned by the Appian ingestor for XML files and ZIP exports
KNOWLEDGE_APPIAN_EXPORTS_DIR=local_data/appian_exports
# Recurse into subdirectories when scanning Appian exports
KNOWLEDGE_APPIAN_EXTRACT_RECURSIVE=true
# Maximum Appian source file size in bytes (50 MB)
KNOWLEDGE_APPIAN_MAX_FILE_BYTES=52428800
# Entity extraction heuristics
KNOWLEDGE_ENTITY_MIN_TOKEN_LEN=3
KNOWLEDGE_ENTITY_MAX_PER_CHUNK=50
# Rule-based linking controls
KNOWLEDGE_LINKING_ENABLE_JIRA_REFS=true
KNOWLEDGE_LINKING_ENABLE_KEYWORD_OVERLAP=true
KNOWLEDGE_LINKING_OVERLAP_THRESHOLD=3
KNOWLEDGE_LINKING_MAX_RELATED_PER_ARTIFACT=25

# -----------------------------------------------------------------------------
# Requirements Studio / Backlog Engineering (Phase 4)
# -----------------------------------------------------------------------------
# Root directory for persisted requirements workspaces, context packs, and drafts
REQUIREMENTS_WORKSPACE_DIR=local_data/requirements_workspaces
# Bounds for context assembly
REQUIREMENTS_CONTEXT_MAX_SEARCH_RESULTS=20
REQUIREMENTS_CONTEXT_MAX_RELATED_RESULTS=10
REQUIREMENTS_CONTEXT_MAX_PINNED_ITEMS=50
# Enable or disable bounded requirements/backlog generation
REQUIREMENTS_GENERATION_ENABLED=true
# Optional dedicated model override; falls back to LLM_MODEL_NAME when blank
# REQUIREMENTS_GENERATION_MODEL_NAME=gpt-4o
# Cap the number of generated story-like backlog items
REQUIREMENTS_STORY_MAX_COUNT=25
# Default split mode: balanced | coarse | detailed
REQUIREMENTS_DEFAULT_STORY_SPLIT_MODE=balanced

# -----------------------------------------------------------------------------
# QA Studio / Playwright Support (Phase 5)
# -----------------------------------------------------------------------------
QA_WORKSPACE_DIR=local_data/qa_workspaces
QA_GENERATION_ENABLED=true
# Optional dedicated model override; falls back to LLM_MODEL_NAME when blank
# QA_GENERATION_MODEL_NAME=gpt-4o
QA_MAX_SCENARIOS_PER_WORKSPACE=30
QA_MAX_NL_SCRIPTS_PER_RUN=20
QA_MAX_EXECUTION_SPECS_PER_RUN=20
# Enable Playwright test generation and optional execution/exploration scaffolding
QA_PLAYWRIGHT_ENABLED=false
# Optional external command used for bounded exploration/execution
# QA_PLAYWRIGHT_COMMAND=python local_tools/run_playwright.py
QA_PLAYWRIGHT_TESTS_DIR=local_data/generated_playwright
QA_PLAYWRIGHT_EVIDENCE_DIR=local_data/playwright_evidence
QA_EXPLORATION_ENABLED=false
QA_MAX_EXPLORATION_STEPS=25
QA_DEFAULT_BROWSER_ROLE=qa
QA_DEFAULT_PROMOTION_STATE=draft
